# PricePulse — Scraper Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to GitHub (it contains secrets)

# ── Supabase (required) ─────────────────────────────
# Found at: supabase.com → Project Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-secret-key

# ── Optional ─────────────────────────────────────────
# Set to 'true' to skip real HTTP calls (useful for testing config)
MOCK_MODE=false

# ── Webhook Alerts (optional) ──────────────────────
# Provide a webhook URL to receive notifications when scrapers fail
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxxx/xxxx
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxxx/xxxx/xxxx
